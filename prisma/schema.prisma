generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  action     String?   @db.VarChar(100)
  entity     String?   @db.VarChar(100)
  entity_id  String?
  metadata   Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model guests {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name    String         @db.VarChar(150)
  email        String?        @db.VarChar(150)
  phone        String?        @db.VarChar(30)
  id_number    String?        @db.VarChar(100)
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  invoices     invoices[]
  orders       orders[]
  reservations reservations[]
}

model housekeeping_tasks {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id     Int?
  assigned_to String?   @db.Uuid
  status      String?   @default("PENDING") @db.VarChar(30)
  notes       String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms       rooms?    @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model invoices {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guest_id       String?       @db.Uuid
  reservation_id String?       @db.Uuid
  total_amount   Decimal?      @db.Decimal(12, 2)
  status         String?       @default("UNPAID") @db.VarChar(30)
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  guests         guests?       @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reservations   reservations? @relation(fields: [reservation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments       payments[]
}

model ledger_entries {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference_type String?   @db.VarChar(50)
  reference_id   String?   @db.Uuid
  entry_type     String?   @db.VarChar(20)
  amount         Decimal   @db.Decimal(12, 2)
  description    String?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
}

model menu_items {
  id           Int           @id @default(autoincrement())
  name         String?       @db.VarChar(100)
  price        Decimal?      @db.Decimal(12, 2)
  is_available Boolean?      @default(true)
  order_items  order_items[]
}

model order_items {
  id           Int         @id @default(autoincrement())
  order_id     String?     @db.Uuid
  menu_item_id Int?
  quantity     Int
  price        Decimal     @db.Decimal(12, 2)
  menu_items   menu_items? @relation(fields: [menu_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders       orders?     @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guest_id     String?       @db.Uuid
  room_id      Int?
  status       String?       @default("OPEN") @db.VarChar(30)
  total_amount Decimal?      @db.Decimal(12, 2)
  created_at   DateTime?     @default(now()) @db.Timestamp(6)
  order_items  order_items[]
  guests       guests?       @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms        rooms?        @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model payments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id String?   @db.Uuid
  amount     Decimal   @db.Decimal(12, 2)
  method     String?   @db.VarChar(30)
  paid_at    DateTime? @default(now()) @db.Timestamp(6)
  invoices   invoices? @relation(fields: [invoice_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model permissions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @unique
  role_permissions role_permissions[]
}

model reservations {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guest_id     String?    @db.Uuid
  room_id      Int?
  check_in     DateTime   @db.Date
  check_out    DateTime   @db.Date
  status       String?    @default("PENDING") @db.VarChar(30)
  total_amount Decimal?   @db.Decimal(12, 2)
  created_at   DateTime?  @default(now()) @db.Timestamp(6)
  invoices     invoices[]
  guests       guests?    @relation(fields: [guest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms        rooms?     @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model roles {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @unique
  role_permissions role_permissions[]
  user_roles       user_roles[]
}

model room_types {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(50)
  description String?
  base_price  Decimal @db.Decimal(12, 2)
  rooms       rooms[]
}

model rooms {
  id                 Int                  @id @default(autoincrement())
  room_number        String               @unique @db.VarChar(20)
  room_type_id       Int?
  status             String?              @default("AVAILABLE") @db.VarChar(30)
  floor              Int?
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  housekeeping_tasks housekeeping_tasks[]
  orders             orders[]
  reservations       reservations[]
  room_types         room_types?          @relation(fields: [room_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model user_roles {
  user_id String @db.Uuid
  role_id String @db.Uuid
  roles   roles  @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users   users  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, role_id])
}

model users {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name          String               @db.VarChar(150)
  email              String               @unique @db.VarChar(150)
  password_hash      String
  phone              String?              @db.VarChar(30)
  is_active          Boolean?             @default(true)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  housekeeping_tasks housekeeping_tasks[]
  user_roles         user_roles[]
}

enum order_status {
  OPEN
  PAID
  CANCELLED
}

enum reservation_status {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum room_status {
  AVAILABLE
  OCCUPIED
  DIRTY
  CLEANING
  MAINTENANCE
}
